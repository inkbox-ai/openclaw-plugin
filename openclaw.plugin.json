{
  "id": "inkbox",
  "name": "Inkbox",
  "description": "Adds Inkbox messaging tools (email, SMS, voice) to OpenClaw",
  "contracts": {
    "tools": [
      "inkbox_send_email",
      "inkbox_send_sms",
      "inkbox_forward_email",
      "inkbox_list_unread_emails",
      "inkbox_list_emails",
      "inkbox_get_email",
      "inkbox_get_email_thread",
      "inkbox_mark_emails_read",
      "inkbox_list_text_conversations",
      "inkbox_get_text_conversation",
      "inkbox_list_texts",
      "inkbox_get_text",
      "inkbox_mark_text_read",
      "inkbox_mark_text_conversation_read",
      "inkbox_list_calls",
      "inkbox_list_call_transcripts",
      "inkbox_lookup_contact",
      "inkbox_get_contact",
      "inkbox_list_contacts",
      "inkbox_create_contact",
      "inkbox_update_contact",
      "inkbox_delete_contact",
      "inkbox_export_contact_vcard",
      "inkbox_list_notes",
      "inkbox_get_note",
      "inkbox_create_note",
      "inkbox_update_note",
      "inkbox_delete_note",
      "inkbox_list_mail_contact_rules",
      "inkbox_create_mail_contact_rule",
      "inkbox_update_mail_contact_rule",
      "inkbox_delete_mail_contact_rule",
      "inkbox_list_phone_contact_rules",
      "inkbox_create_phone_contact_rule",
      "inkbox_update_phone_contact_rule",
      "inkbox_delete_phone_contact_rule",
      "inkbox_list_contact_access",
      "inkbox_grant_contact_access",
      "inkbox_revoke_contact_access",
      "inkbox_list_note_access",
      "inkbox_grant_note_access",
      "inkbox_revoke_note_access",
      "inkbox_credentials_list",
      "inkbox_credentials_get_login",
      "inkbox_credentials_get_api_key",
      "inkbox_credentials_get_ssh_key",
      "inkbox_totp_code",
      "inkbox_whoami",
      "inkbox_place_call"
    ]
  },
  "skills": ["./skills"],
  "channels": ["inkbox"],
  "channelConfigs": {
    "inkbox": {
      "schema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": { "type": "boolean" },
          "name": { "type": "string" },
          "defaultAccount": { "type": "string" },
          "defaultTo": {
            "type": "string",
            "description": "Default target for outbound messages, such as email:user@example.com or sms:+14155550123."
          },
          "apiKey": {
            "type": "string",
            "description": "Inkbox API key (ApiKey_... format)."
          },
          "identity": {
            "type": "string",
            "description": "Agent identity handle to send from."
          },
          "baseUrl": {
            "type": "string",
            "description": "Override Inkbox API base URL."
          },
          "signingKey": {
            "type": "string",
            "description": "Webhook HMAC signing secret."
          },
          "tunnelName": {
            "type": "string",
            "description": "Override the Inkbox tunnel name."
          },
          "publicUrl": {
            "type": "string",
            "description": "Public OpenClaw URL. If omitted, the plugin uses an Inkbox tunnel."
          },
          "allowedRecipients": {
            "type": "array",
            "items": { "type": "string" }
          },
          "allowedInboundContactIds": {
            "type": "array",
            "items": { "type": "string" }
          },
          "sms": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "batchDelayMs": { "type": "integer", "minimum": 0 },
              "maxMessages": { "type": "integer", "minimum": 1 },
              "maxChars": { "type": "integer", "minimum": 1 }
            }
          },
          "voiceRealtime": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "enabled": { "type": "boolean" },
              "provider": { "type": "string" },
              "model": { "type": "string" },
              "voice": { "type": "string" },
              "instructions": { "type": "string" },
              "toolPolicy": {
                "type": "string",
                "enum": ["safe-read-only", "owner", "none"]
              },
              "consultPolicy": {
                "type": "string",
                "enum": ["auto", "substantive", "always"]
              },
              "providers": {
                "type": "object",
                "additionalProperties": {
                  "type": "object",
                  "additionalProperties": true
                }
              },
              "fallbackToInkboxSttTts": { "type": "boolean" }
            }
          },
          "vault": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "keyEnvVar": { "type": "string" }
            }
          },
          "accounts": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "enabled": { "type": "boolean" },
                "name": { "type": "string" },
                "defaultTo": { "type": "string" },
                "apiKey": { "type": "string" },
                "identity": { "type": "string" },
                "baseUrl": { "type": "string" },
                "signingKey": { "type": "string" },
                "tunnelName": { "type": "string" },
                "publicUrl": { "type": "string" },
                "allowedRecipients": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "allowedInboundContactIds": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "sms": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "batchDelayMs": { "type": "integer", "minimum": 0 },
                    "maxMessages": { "type": "integer", "minimum": 1 },
                    "maxChars": { "type": "integer", "minimum": 1 }
                  }
                },
                "voiceRealtime": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "enabled": { "type": "boolean" },
                    "provider": { "type": "string" },
                    "model": { "type": "string" },
                    "voice": { "type": "string" },
                    "instructions": { "type": "string" },
                    "toolPolicy": {
                      "type": "string",
                      "enum": ["safe-read-only", "owner", "none"]
                    },
                    "consultPolicy": {
                      "type": "string",
                      "enum": ["auto", "substantive", "always"]
                    },
                    "providers": {
                      "type": "object",
                      "additionalProperties": {
                        "type": "object",
                        "additionalProperties": true
                      }
                    },
                    "fallbackToInkboxSttTts": { "type": "boolean" }
                  }
                },
                "vault": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "keyEnvVar": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "toolMetadata": {
    "inkbox_forward_email": { "optional": true },
    "inkbox_mark_emails_read": { "optional": true },
    "inkbox_list_texts": { "optional": true },
    "inkbox_get_text": { "optional": true },
    "inkbox_mark_text_read": { "optional": true },
    "inkbox_mark_text_conversation_read": { "optional": true },
    "inkbox_update_contact": { "optional": true },
    "inkbox_delete_contact": { "optional": true },
    "inkbox_export_contact_vcard": { "optional": true },
    "inkbox_update_note": { "optional": true },
    "inkbox_delete_note": { "optional": true },
    "inkbox_list_mail_contact_rules": { "optional": true },
    "inkbox_create_mail_contact_rule": { "optional": true },
    "inkbox_update_mail_contact_rule": { "optional": true },
    "inkbox_delete_mail_contact_rule": { "optional": true },
    "inkbox_list_phone_contact_rules": { "optional": true },
    "inkbox_create_phone_contact_rule": { "optional": true },
    "inkbox_update_phone_contact_rule": { "optional": true },
    "inkbox_delete_phone_contact_rule": { "optional": true },
    "inkbox_list_contact_access": { "optional": true },
    "inkbox_grant_contact_access": { "optional": true },
    "inkbox_revoke_contact_access": { "optional": true },
    "inkbox_list_note_access": { "optional": true },
    "inkbox_grant_note_access": { "optional": true },
    "inkbox_revoke_note_access": { "optional": true },
    "inkbox_credentials_list": { "optional": true },
    "inkbox_credentials_get_login": { "optional": true },
    "inkbox_credentials_get_api_key": { "optional": true },
    "inkbox_credentials_get_ssh_key": { "optional": true },
    "inkbox_totp_code": { "optional": true },
    "inkbox_whoami": { "optional": true },
    "inkbox_place_call": { "optional": true }
  },
  "activation": {
    "onStartup": true
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "apiKey": {
        "type": "string",
        "description": "Inkbox API key (ApiKey_... format). Create one in the Inkbox Console."
      },
      "identity": {
        "type": "string",
        "description": "Agent identity handle to send from (3–63 lowercase alphanum/dash)."
      },
      "baseUrl": {
        "type": "string",
        "description": "Override Inkbox API base URL. Defaults to https://inkbox.ai."
      },
      "signingKey": {
        "type": "string",
        "description": "Webhook HMAC signing secret. Required when inbound webhooks are enabled."
      },
      "tunnelName": {
        "type": "string",
        "description": "Override the Inkbox tunnel name. Defaults to the identity handle so the public URL is stable across restarts."
      },
      "publicUrl": {
        "type": "string",
        "description": "If set, skip the Inkbox tunnel and assume webhooks land at this public URL. Used when OpenClaw is hosted on a publicly reachable host."
      },
      "vault": {
        "type": "object",
        "additionalProperties": false,
        "description": "Vault tool configuration. Vault tools are optional and must be opted into via tools.allow.",
        "properties": {
          "keyEnvVar": {
            "type": "string",
            "description": "Env var the vault unlock key is read from. Defaults to INKBOX_VAULT_KEY."
          }
        }
      },
      "allowedRecipients": {
        "type": "array",
        "items": { "type": "string" },
        "description": "Outbound recipient allowlist. When set, send_email / send_sms / forward_email reject any recipient (to/cc/bcc) not on this list. Phone numbers in E.164, emails as exact addresses."
      },
      "allowedInboundContactIds": {
        "type": "array",
        "items": { "type": "string" },
        "description": "Inbound contact-id allowlist. When set, webhook events whose remote contact id is not on this list are dropped (mail/text become no-ops, calls are rejected). Events with no contact resolution are also dropped."
      },
      "sms": {
        "type": "object",
        "additionalProperties": false,
        "description": "Inbound SMS fragment batching. Useful when senders split a message across multiple texts in rapid succession — collapses them into one logical event.",
        "properties": {
          "batchDelayMs": {
            "type": "integer",
            "minimum": 0,
            "description": "Wait this many ms of inactivity from a sender before flushing the batch. 0 disables batching."
          },
          "maxMessages": {
            "type": "integer",
            "minimum": 1,
            "description": "Max fragments per batch before forced flush. Default 8."
          },
          "maxChars": {
            "type": "integer",
            "minimum": 1,
            "description": "Max total chars per batch before forced flush. Default 4000."
          }
        }
      },
      "voiceRealtime": {
        "type": "object",
        "additionalProperties": false,
        "description": "Raw call-media bridge to an OpenClaw realtime voice provider. Falls back to Inkbox STT/TTS by default when unavailable.",
        "properties": {
          "enabled": {
            "type": "boolean",
            "description": "Enable raw phone-media bridging through an OpenClaw realtime voice provider."
          },
          "provider": {
            "type": "string",
            "description": "Realtime voice provider id, for example openai."
          },
          "model": {
            "type": "string",
            "description": "Provider realtime model, for example gpt-realtime."
          },
          "voice": {
            "type": "string",
            "description": "Provider voice, for example alloy, cedar, or marin."
          },
          "instructions": {
            "type": "string",
            "description": "Additional realtime voice instructions."
          },
          "toolPolicy": {
            "type": "string",
            "enum": ["safe-read-only", "owner", "none"],
            "description": "Realtime consult tool policy. owner lets the OpenClaw consult use the normal agent tool policy."
          },
          "consultPolicy": {
            "type": "string",
            "enum": ["auto", "substantive", "always"],
            "description": "Guidance for when the realtime model should call openclaw_agent_consult."
          },
          "providers": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "additionalProperties": true
            },
            "description": "Provider-owned realtime config keyed by provider id, such as { openai: { apiKey, model, voice } }."
          },
          "fallbackToInkboxSttTts": {
            "type": "boolean",
            "description": "Fall back to Inkbox-managed STT/TTS when realtime auth/provider config is unavailable. Defaults to true."
          }
        }
      }
    }
  }
}
